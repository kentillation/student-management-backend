Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "firstName": "",
  "lastName": "",
  "email": "",
  "phone": "",
  "course": "",
  "enrollmentDate": "",
  "gpa": 
}

### Step 3: Get All Students
GET {{apiUrl}}/students
Authorization: Bearer {{adminToken}}

### Step 4: Update Student
PUT {{apiUrl}}/students/3
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "id": 1,
  "firstName": "",
  "lastName": "",
  "email": "",
  "phone": "",
  "course": "",
  "enrollmentDate": "",
  "gpa": 
}

### Step 5: Delete Student
DELETE {{apiUrl}}/students/3
Authorization: Bearer {{adminToken}}

### Scenario 3: Search and Export Flow
### Step 1: Login as Admin
POST {{apiUrl}}/auth/login
Content-Type: application/json

{
  "email": "",
  "password": ""
}

### Step 2: Search Students
GET {{apiUrl}}/students/search?searchTerm=Computer&minGPA=3.0
Authorization: Bearer {{adminToken}}

### Step 3: Export Results to CSV
GET {{apiUrl}}/export/csv?course=Computer%20Science
Authorization: Bearer {{adminToken}}

### Step 4: Export Results to Excel
GET {{apiUrl}}/export/excel
Authorization: Bearer {{adminToken}}

### ========================================
### ERROR TESTING SCENARIOS
### ========================================

### Error 1: Login with Invalid Credentials
POST {{apiUrl}}/auth/login
Content-Type: application/json

{
  "email": "",
  "password": ""
}

### Error 2: Register with Existing Email
POST {{apiUrl}}/auth/register
Content-Type: application/json

{
  "firstName": "",
  "lastName": "",
  "email": "",
  "password": "",
  "confirmPassword": ""
}

### Error 3: Access Without Token
GET {{apiUrl}}/students

### Error 4: Access with Invalid Token
GET {{apiUrl}}/students
Authorization: Bearer invalid_token_here

### Error 5: Get Non-existent Student
GET {{apiUrl}}/students/999
Authorization: Bearer {{authToken}}

### Error 6: Update with ID Mismatch
PUT {{apiUrl}}/students/1
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "id": 1,
  "firstName": "",
  "lastName": "",
  "email": "",
  "phone": "",
  "course": "",
  "enrollmentDate": "",
  "gpa": 
}

### Error 7: Create Student with Invalid Data
POST {{apiUrl}}/students
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "",
  "lastName": "",
  "email": "",
  "phone": "",
  "course": "",
  "enrollmentDate": "",
  "gpa": 
}

### Error 8: Delete Non-existent Student
DELETE {{apiUrl}}/students/999
Authorization: Bearer {{authToken}}

### ========================================
### PERFORMANCE TESTING
### ========================================

### Performance Test: Get All Students (Large Dataset)
GET {{apiUrl}}/students
Authorization: Bearer {{authToken}}

### Performance Test: Search with Multiple Filters
GET {{apiUrl}}/students/search?searchTerm=a&course=Computer%20Science&minGPA=2.0&maxGPA=4.0
Authorization: Bearer {{authToken}}

### Performance Test: Paginated Request
GET {{apiUrl}}/students/paginated?pageNumber=5&pageSize=50
Authorization: Bearer {{authToken}}

### ========================================
### BULK OPERATIONS TESTING
### ========================================

### Bulk Create Students (Run multiple times with different data)
POST {{apiUrl}}/students
Authorization: Bearer {{authToken}}
Content-Type: application/json

{
  "firstName": "Bulk",
  "lastName": "Student{{$randomInt 1 1000}}",
  "email": "bulk.student{{$randomInt 1 1000}}@example.com",
  "phone": "555-{{$randomInt 100 999}}-{{$randomInt 1000 9999}}",
  "course": "",
  "enrollmentDate": "",
  "gpa": {{$randomFloat 2.0 4.0}}
}

